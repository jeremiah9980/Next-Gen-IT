{\n    "version": "0.2.0",\n    "name": "Next Gen IT Development Container",\n    "settings": {\n        // Place any VS Code settings here\n    },\n    "extensions": [\n        // List extensions to be installed\n        "dbaeumer.vscode-eslint",\n        "esbenp.prettier-vscode",\n        "ms-azuretools.vscode-docker"\n    ],\n    "postCreateCommand": {\n        "command": [\n            "npm install", // Command to install frontend dependencies\n            "npm run setup-db" // Command to initialize the database\n        ],\n        "args": {\n            "timeout": 300 // Set timeout for the commands (in seconds)\n        }\n    }\n}